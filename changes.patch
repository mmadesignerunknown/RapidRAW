+      isEffectActive = false;
+    };
+  }, [showOriginal, selectedImage?.path, adjustments, transformedOriginalUrl, calculateTargetRes, setEditor]);
+
+  return {
+    applyAdjustments,
+    executeApplyAdjustments,
+  };
+}
