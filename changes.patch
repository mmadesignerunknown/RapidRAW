+        },
+        {
+          icon: CopyPlus,
+          label: 'Duplicate Image',
+          disabled: !isSingleSelection,
+          submenu: [
+            {
+              label: 'Physical Copy',
+              icon: Copy,
+              onClick: async () => {
+                try {
