+        onSave={props.handleCreateFolder}
+      />
+      <RenameFolderModal
+        currentName={folderActionTarget ? folderActionTarget.split(/[\\/]/).pop() : ''}
+        isOpen={isRenameFolderModalOpen}
+        onClose={() => setUI({ isRenameFolderModalOpen: false })}
+        onSave={props.handleRenameFolder}
