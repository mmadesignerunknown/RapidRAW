+        { type: OPTION_SEPARATOR },
+        { label: 'Undo', icon: Undo, onClick: undo, disabled: !canUndo },
+        { label: 'Redo', icon: Redo, onClick: redo, disabled: !canRedo },
+        { type: OPTION_SEPARATOR },
+        { label: 'Copy Adjustments', icon: Copy, onClick: handleCopyAdjustments },
