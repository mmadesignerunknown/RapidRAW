+              label: 'Auto Adjust Image',
+              icon: Aperture,
+              onClick: handleAutoAdjustments,
+              disabled: !selectedImage?.isReady,
+            },
+            {
+              label: 'Denoise Image',
+              icon: Grip,
+              onClick: () => {
