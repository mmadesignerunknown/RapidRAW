+          label: 'Paste Adjustments',
+          icon: ClipboardPaste,
+          onClick: () => handlePasteAdjustments(),
+          disabled: copiedAdjustments === null,
+        },
+        {
+          label: 'Productivity',
+          icon: Gauge,
+          submenu: [
