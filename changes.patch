+            }
+            if (libraryActivePath && finalSelection.includes(libraryActivePath)) {
+              const metadata: any = await invoke(Invokes.LoadMetadata, { path: libraryActivePath });
+              if (metadata.adjustments && !metadata.adjustments.is_null) {
